# Frontend (Flutter Web) Environment Variables
# Variables no son usadas en build-time pero útiles para documentación

# API Endpoint
FLUTTER_API_URL=https://yourdomain.com/api
FLUTTER_GRAPHQL_URL=https://yourdomain.com/graphql/

# App Info
FLUTTER_APP_NAME=SGA1
FLUTTER_APP_VERSION=1.0.0
FLUTTER_ENVIRONMENT=production

# Analytics (Optional)
FLUTTER_ANALYTICS_ENABLED=False
SENTRY_DSN_FLUTTER=

# WhatsApp/Evolution API (Optional)
EVOLUTION_API_URL=https://tu-evolution-instance.com
EVOLUTION_INSTANCE_NAME=conservatorio

# Feature Flags
ENABLE_DARK_MODE=True
ENABLE_OFFLINE_MODE=False
