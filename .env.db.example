# Database (PostgreSQL) Environment Variables

# PostgreSQL Core
POSTGRES_DB=music_registry_db
POSTGRES_USER=music_user
POSTGRES_PASSWORD=your-super-secure-password-min-20-chars
POSTGRES_INITDB_ARGS=--encoding=UTF8 --locale=C

# Backup & Maintenance
POSTGRES_BACKUP_ENABLED=True
POSTGRES_MAINTENANCE_ENABLED=True

# Performance Tuning
# shared_buffers: 25% of RAM (for 4GB: 1GB = 262144)
# work_mem: RAM / (max_connections * 2) (for 100 conn, 4GB: 20MB = 20480)
POSTGRES_SHARED_BUFFERS=262144  # in 8KB pages (1GB for 4GB RAM)
POSTGRES_WORK_MEM=20480          # in KB
POSTGRES_MAINTENANCE_WORK_MEM=524288  # in KB (512MB)
POSTGRES_EFFECTIVE_CACHE_SIZE=1048576  # in 8KB pages (8GB assumed)

# Extensions
POSTGRES_EXTENSIONS=uuid-ossp,pg_stat_statements
